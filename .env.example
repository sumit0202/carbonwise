# CarbonWise environment variables.
# Copy to ".env.local" for local development. Never commit real keys.
# The app runs fully in demo mode when these are empty.

# Server-side key used by Next route handlers to proxy Google APIs
# (Geocoding, Routes, Places, Air Quality, Solar, Pollen, Time Zone).
# This value MUST NOT be exposed to the browser.
GOOGLE_MAPS_SERVER_API_KEY=

# Public browser key for the Maps JavaScript API only.
# Restrict it by HTTP referrer and by API in the Google Cloud Console.
GOOGLE_MAPS_BROWSER_API_KEY=

# Standard Node environment ("development" | "production" | "test").
NODE_ENV=
